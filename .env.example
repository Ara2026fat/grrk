# GRRK — copy this file to .env.local and fill in the two Supabase values.
# .env.local is already in .gitignore — never commit real credentials.
VITE_APP_NAME=GRRK
VITE_DEFAULT_LOCALE=ar
VITE_BACKEND_DRIVER=supabase

# ---- The only two values you need to set ----
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
